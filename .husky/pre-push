#!/bin/sh

# Get the current branch name
BRANCH=$(git rev-parse --abbrev-ref HEAD)

# Only block direct pushes to main - other branches are free
if [ "$BRANCH" = "main" ] && [ "$MYOPERATOR_GIT_ALLOWED" != "1" ]; then
  echo ""
  echo "╔══════════════════════════════════════════════════════════════════╗"
  echo "║                    ⛔ PUSH TO MAIN BLOCKED ⛔                    ║"
  echo "╠══════════════════════════════════════════════════════════════════╣"
  echo "║                                                                  ║"
  echo "║  Direct push to 'main' is not allowed.                          ║"
  echo "║                                                                  ║"
  echo "║  Use the /publish-all command instead, which ensures:           ║"
  echo "║    ✓ Proper version management                                  ║"
  echo "║    ✓ All validations pass                                       ║"
  echo "║    ✓ Correct commit messages                                    ║"
  echo "║    ✓ Synchronized package versions                              ║"
  echo "║                                                                  ║"
  echo "║  Pushing to other branches (beta/cli, feature/*) is allowed.   ║"
  echo "║                                                                  ║"
  echo "╚══════════════════════════════════════════════════════════════════╝"
  echo ""
  exit 1
fi

if [ "$BRANCH" = "main" ]; then
  echo "✓ Push to main authorized via /publish-all"
else
  echo "✓ Push to $BRANCH allowed"
fi

#!/bin/sh

# Block direct commits - only allow via /publish-all command
if [ "$MYOPERATOR_GIT_ALLOWED" != "1" ]; then
  echo ""
  echo "╔══════════════════════════════════════════════════════════════════╗"
  echo "║                    ⛔ COMMIT BLOCKED ⛔                          ║"
  echo "╠══════════════════════════════════════════════════════════════════╣"
  echo "║                                                                  ║"
  echo "║  Direct 'git commit' is not allowed in this repository.         ║"
  echo "║                                                                  ║"
  echo "║  Use the /publish-all command instead, which ensures:           ║"
  echo "║    ✓ Proper version management                                  ║"
  echo "║    ✓ All validations pass                                       ║"
  echo "║    ✓ Correct commit messages                                    ║"
  echo "║    ✓ Synchronized package versions                              ║"
  echo "║                                                                  ║"
  echo "╚══════════════════════════════════════════════════════════════════╝"
  echo ""
  exit 1
fi

echo "✓ Commit authorized via /publish-all"

# Check that all components have test files
node scripts/check-component-tests.js || exit 1

# Validate CVA props alignment (prevents TypeScript consumer errors)
node scripts/validate-cva-props.js || exit 1

# Ensure all <p> elements have m-0 (Bootstrap compat — prevents margin-bottom: 1rem bleed)
node scripts/check-bootstrap-compat.js || exit 1

# Run lint-staged
npx lint-staged
